    "from kafka import KafkaConsumer\n",
    "\n",
    "consumer = KafkaConsumer(\n",
    "    'test-topic',\n",
    "    bootstrap_servers='localhost:9092',\n",
    "    auto_offset_reset='earliest'\n",
    ")\n",
    "\n",
    "for message in consumer:\n",
    "    print(\"Received:\", message.value.decode())"
